# Supabase / Postgres connection for SF6 data
# Supabase format: postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/games

# Player config
PLAYER_CFN=braventooth
MY_PLAYER_ID=                        # Your Buckler numeric player ID (required for --scrape)

# Buckler scrape config (only needed for prep_session.py --scrape)
BUCKLER_PROJECT_PATH=                # Absolute path to the street_fighter project root
COOKIES_PATH=                        # Path to buckler_cookies.json (defaults to BUCKLER_PROJECT_PATH/buckler_cookies.json)
SESSION_GAP_HOURS=3                  # Hours between matches that define a session boundary

# Output directory for generated artifacts
OUTPUT_DIR=artifacts
